# ========================================
# MARIGOLD — 환경 변수 템플릿
# 실제 값으로 채워 .env 로 복사한 뒤 사용
# ========================================

# Application
NODE_ENV=development
# 로컬 개발: 3000  /  운영(PM2): 3004 (ecosystem.config.cjs 가 덮어씀)
PORT=3000

# PostgreSQL
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SCHEMA=marigold

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=1d

# Uploads
UPLOAD_ROOT=./uploads

# CORS
CORS_ORIGIN=http://localhost:5173
